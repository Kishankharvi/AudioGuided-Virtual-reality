  m_Name: ExerciseInfo_FingerTapping
  m_EditorClassIdentifier: 
  _displayName: Finger Tapping
  _description: Rapidly tap your index finger to your thumb tip. Each clean touch
    counts as one tap. This exercise improves finger dexterity, coordination, and
    fine motor speed.
  _techniqueTips: '- Use your right hand for this exercise

    - Make crisp contact
    between index and thumb tips

    - Keep other fingers relaxed and extended

    -
    Maintain a steady rhythm, avoid rushing'
  _illustration: {fileID: 21300000, guid: f5870a91fbeec824baab3f48a1460d8c, type: 3}
  _accentColor: {r: 0.4, g: 0.65, b: 0.92, a: 1}
  _targetReps: 20
  _difficulty: Moderate
