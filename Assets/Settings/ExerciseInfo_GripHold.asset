  m_Name: ExerciseInfo_GripHold
  m_EditorClassIdentifier: 
  _displayName: Grip & Hold
  _description: Grab the virtual sphere and hold it firmly for 3 seconds without
    releasing. This exercise strengthens your grip endurance and builds the hand
    muscles needed for daily tasks like opening jars or carrying bags.
  _techniqueTips: '- Wrap all fingers evenly around the object

    - Keep your wrist
    neutral, not bent

    - Breathe steadily while holding

    - Release slowly
    and controlled'
  _illustration: {fileID: 21300000, guid: df954b56d0f90bc46aa70b4bda0b3a68, type: 3}
  _accentColor: {r: 0.3, g: 0.78, b: 0.45, a: 1}
  _targetReps: 5
  _difficulty: Easy
