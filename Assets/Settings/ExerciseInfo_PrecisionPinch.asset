  m_Name: ExerciseInfo_PrecisionPinch
  m_EditorClassIdentifier: 
  _displayName: Precision Pinching
  _description: Pinch your index finger and thumb together firmly (85%+ strength)
    and hold the pinch steady for 1.5 seconds. Releasing early counts as a failed
    attempt. This trains precise grip control needed for writing and handling small
    objects.
  _techniqueTips: "- Pinch with the pads of your fingertips\n- Keep your hand steady,
    avoid wrist movement\n- Focus on consistent pressure, not maximum force\n- Both
    hands are tracked \u2014 use whichever is stronger"
  _illustration: {fileID: 21300000, guid: f5870a91fbeec824baab3f48a1460d8c, type: 3}
  _accentColor: {r: 0.88, g: 0.55, b: 0.25, a: 1}
  _targetReps: 10
  _difficulty: Hard
