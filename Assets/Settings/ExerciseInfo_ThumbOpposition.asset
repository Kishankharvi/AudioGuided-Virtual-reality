  _displayName: Thumb Opposition
  _description: "Touch your thumb to each fingertip in sequence: Index \u2192 Middle
    \u2192 Ring \u2192 Pinky. Complete the full sequence within the time limit. This
    exercise develops thumb dexterity and multi-finger coordination essential for
    hand rehabilitation."
  _techniqueTips: "- Use your right hand for this exercise\n- Touch each fingertip
    firmly (75%+ pinch strength)\n- Release fully before moving to the next finger\n-
    Keep the sequence smooth \u2014 gaps over 0.5s reset progress"
  _illustration: {fileID: 21300000, guid: a789df707d6812b4493109d780f5ec14, type: 3}
  _accentColor: {r: 0.9, g: 0.35, b: 0.4, a: 1}
  _targetReps: 6
  _difficulty: Hard
